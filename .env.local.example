# Supabase (선택 — 없으면 로컬 `.data/books.json` 사용)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# MarkItDown (PDF/Word 등 → Markdown 변환)
# 로컬: pip install -r requirements-markitdown.txt 후 Python subprocess 사용
# Vercel/프로덕션: services/markitdown-api Docker 배포 후 URL 설정
# MARKITDOWN_PYTHON=python
# MARKITDOWN_SERVICE_URL=https://your-markitdown-api.onrender.com

# PPT Master (AI 프레젠테이션 생성)
# 로컬: npm run setup:ppt-master
# PPT_MASTER_ROOT=../ppt-master
# PPT_MASTER_PYTHON=python
# PPT_AI_API_KEY=sk-...  (없으면 책 마크다운 기반 로컬 플래너 사용)
# PPT_AI_BASE_URL=https://api.openai.com/v1
# PPT_AI_MODEL=gpt-4o-mini

# AionUi Cowork (멀티에이전트 WebUI + Studio Chat)
# 로컬: npm run setup:aionui && npm run start:aionui
# AIONUI_ROOT=../AionUi
# AIONUI_WEB_URL=https://your-aionui-host.example.com
# AIONUI_PORT=25809
# COWORK_AI_API_KEY=sk-...  (없으면 OPENAI_API_KEY 사용)
# COWORK_AI_BASE_URL=https://api.openai.com/v1
# COWORK_AI_MODEL=gpt-4o-mini
